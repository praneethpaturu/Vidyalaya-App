{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma migrate deploy && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["bom1"],
  "crons": [
    { "path": "/api/digest",                 "schedule": "30 1 * * 0" },
    { "path": "/api/outbox/flush",           "schedule": "0 2 * * *" },
    { "path": "/api/finance/late-fee/accrue","schedule": "30 2 * * *" },
    { "path": "/api/connect/drip/fire",      "schedule": "0 */2 * * *" }
  ]
}
