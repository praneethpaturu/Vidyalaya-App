{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma migrate deploy && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["bom1"],
  "crons": [
    { "path": "/api/digest",     "schedule": "30 1 * * 0" },
    { "path": "/api/cron/daily", "schedule": "0 2 * * *" }
  ]
}
