  @@unique([schoolId, staffId])
}

model CanteenTransaction {
  id        String   @id @default(cuid())
  schoolId  String
  walletId  String
  type      String   // TOPUP | CHARGE | REFUND
  amount    Int      // paise
  itemSnapshot String?  // JSON
  balance   Int       // wallet balance after txn
