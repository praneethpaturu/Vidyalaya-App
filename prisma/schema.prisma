// Dynamic Forms
model DynamicForm {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  description String?
  schema    String   // JSON: list of fields
  audience  String   @default("ALL")  // ALL | STAFF | STUDENTS | PARENTS
