  @@index([schoolId, createdAt])
}

// School Store
model StoreItem {
  id         String  @id @default(cuid())
  schoolId   String
  sku        String
  name       String
  category   String  // UNIFORM | BOOK | STATIONERY | OTHER
  price      Int
  qtyOnHand  Int     @default(0)

  @@unique([schoolId, sku])
}

model StoreSale {
  id           String   @id @default(cuid())
  schoolId     String
  receiptNo    String
  studentId    String?
  itemSnapshot String   // JSON: [{ itemId, name, qty, price }]
  total        Int
  paymentMethod String  @default("CASH")
  refunded     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([schoolId, receiptNo])
  @@index([schoolId, createdAt])
