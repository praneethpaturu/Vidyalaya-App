  submissions DynamicFormSubmission[]
}

model DynamicFormSubmission {
  id        String   @id @default(cuid())
  formId    String
  submittedById String?
  data      String   // JSON
  submittedAt DateTime @default(now())

  form      DynamicForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
}

// Login statistics
model LoginEvent {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String
  email     String
  success   Boolean  @default(true)
  ip        String?
  userAgent String?
  device    String?  // WEB | ANDROID | IOS
  loggedAt  DateTime @default(now())

