  schoolId  String
  name      String  // Reference | Textbook | Fiction | Periodical | Magazine
  active    Boolean @default(true)

  @@unique([schoolId, name])
}

model LibraryPublisher {
  id        String  @id @default(cuid())
  schoolId  String
  name      String
  contact   String?
  email     String?
  active    Boolean @default(true)

  @@unique([schoolId, name])
}

// Member type x Category -> days
model LibraryReturnDays {
  id          String  @id @default(cuid())
  schoolId    String
  memberType  String  // STUDENT | STAFF
  category    String
  days        Int
  graceDays   Int     @default(0)
  excludeWeekends Boolean @default(false)

  @@unique([schoolId, memberType, category])
}

model LibraryMaximumBooks {
  id          String  @id @default(cuid())
  schoolId    String
  memberType  String
  category    String
  maxBooks    Int
  classId     String?

  @@unique([schoolId, memberType, category, classId])
}

model LibraryFineRule {
  id          String  @id @default(cuid())
  schoolId    String
  category    String
  daysFrom    Int     // bucket lower bound (overdue days)
  daysTo      Int     // bucket upper bound; -1 = ∞
  amountPerDay Int    @default(0)   // paise
