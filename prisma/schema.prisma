  schoolId   String
  authorId   String
  authorName String
  audience   String   @default("STAFF") // STAFF | STUDENTS | ALL
  body       String
  attachments String  @default("[]")
  pinned     Boolean  @default(false)
  flagged    Boolean  @default(false)
  createdAt  DateTime @default(now())

  comments   WallComment[]

  @@index([schoolId, createdAt])
}

model WallComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  authorName String
  body      String
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())

  post      WallPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ============================================================
// Subjects master + Learning taxonomy
// ============================================================
model SubjectMaster {
  id        String  @id @default(cuid())
  schoolId  String
  name      String
  code      String
  hasTheory Boolean @default(true)
  hasPractical Boolean @default(false)
  creditHours Int   @default(4)
  boardCsv  String  @default("CBSE")

  @@unique([schoolId, code])
}

model LearningTaxonomy {
  id        String  @id @default(cuid())
  schoolId  String
  name      String  // "Bloom", "SOLO"
  levelsCsv String  // "Remember,Understand,Apply,Analyse,Evaluate,Create"
  active    Boolean @default(true)

  @@unique([schoolId, name])
}

// ============================================================
// Reflections (student/teacher journal)
// ============================================================
model Reflection {
  id        String   @id @default(cuid())
  schoolId  String
  authorId  String
  authorRole String  // STUDENT | TEACHER
  mood      String?  // HAPPY | OK | TIRED | ANXIOUS | EXCITED
  title     String?
  body      String
  createdAt DateTime @default(now())

  @@index([schoolId, authorId])
}

// ============================================================
// Baseline analysis (LMS)
// ============================================================
model BaselineAssessment {
  id           String   @id @default(cuid())
  schoolId     String
  classId      String
  subjectId    String?
  type         String   @default("PRE")  // PRE | POST
  conductedAt  DateTime
  scores       String   // JSON: { studentId: score }
  totalMarks   Int
  notes        String?

  @@index([schoolId, classId])
}

// ============================================================
// Approvals (cross-module workflow queue)
// kind: ADMISSION | FEE_WAIVER | TC | DOC_EDIT | LEAVE | EXPENSE | REFUND | CONCESSION
// status: PENDING | APPROVED | REJECTED
// ============================================================
model ApprovalRequest {
  id           String   @id @default(cuid())
  schoolId     String
  kind         String
  refEntity    String?
  refId        String?
  summary      String
  payload      String   @default("{}")  // JSON
  requestedById String?
  approverId   String?
  status       String   @default("PENDING")
  decidedAt    DateTime?
  comment      String?
  createdAt    DateTime @default(now())

  @@index([schoolId, status])
  @@index([schoolId, kind])
}

// ============================================================
// Student favourite menus / saved pages
// ============================================================
model FavouriteMenu {
  id        String   @id @default(cuid())
  userId    String
  href      String
  label     String
  createdAt DateTime @default(now())

  @@unique([userId, href])
}

// ============================================================
// Visitor / Mentor / Hostel etc - more relations done.
// ============================================================

// ============================================================
// AI Insights (additive — new module sitting alongside existing data)
// ============================================================

// Generic insight produced by an AI feature; consumed by listing pages.
// kind examples: LEAD_SCORE | AT_RISK | DELINQUENCY | DRIVER_SCORE | ANOMALY |
//                COMPATIBILITY | MAINTENANCE | LEAVE_FORECAST | LEARNING_GAP
model AiInsight {
  id         String   @id @default(cuid())
  schoolId   String
  kind       String
  refEntity  String?  // "AdmissionEnquiry" | "Student" | "Bus" | "Staff" | ...
  refId      String?
  score      Float?   // 0..1
  band       String?  // "HIGH" | "MEDIUM" | "LOW" | model-specific
  reason     String?  // short human-readable rationale
  payload    String   @default("{}") // JSON for extra fields
  computedAt DateTime @default(now())

  @@index([schoolId, kind])
  @@index([refEntity, refId])
}

// AI-generated suggestions awaiting human review (essay grades, narrative drafts,
// translations, draft replies, etc.). status = PENDING | ACCEPTED | REJECTED.
model AiSuggestion {
  id         String   @id @default(cuid())
  schoolId   String
  kind       String   // ESSAY_GRADE | HPC_NARRATIVE | TRANSLATION | DRAFT_REPLY | QUIZ_GEN | ...
  refEntity  String?
  refId      String?
  prompt     String
  output     String
  meta       String   @default("{}")
  status     String   @default("PENDING")
  authorId   String?  // user who triggered
  reviewerId String?
  decidedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([schoolId, kind, status])
}

// Audit trail for every AI call (privacy / cost / debugging).
model AiAuditLog {
  id         String   @id @default(cuid())
  schoolId   String
  userId     String?
  feature    String
  provider   String   // "anthropic" | "stub"
  model      String?
  tokensIn   Int      @default(0)
  tokensOut  Int      @default(0)
  latencyMs  Int      @default(0)
  ok         Boolean  @default(true)
  errorMsg   String?
  createdAt  DateTime @default(now())

  @@index([schoolId, feature])
  @@index([schoolId, createdAt])
}

// Cached embeddings for semantic search / RAG.
// vector is a JSON array of floats; SQLite has no native vector type so we
// keep it portable. Cosine similarity computed in-memory.
model AiEmbedding {
  id         String   @id @default(cuid())
  schoolId   String
  refEntity  String   // "Student" | "Circular" | "Book" | "Concern" | ...
  refId      String
  text       String
  vector     String   // JSON float[]
  dim        Int
  createdAt  DateTime @default(now())

  @@unique([schoolId, refEntity, refId])
  @@index([schoolId, refEntity])
}

// Roommate compatibility scores (cached pairwise).
model AiCompatibility {
  id         String  @id @default(cuid())
  schoolId   String
  studentAId String
  studentBId String
  score      Float
  reasons    String  @default("[]") // JSON array
  computedAt DateTime @default(now())

  @@unique([schoolId, studentAId, studentBId])
  @@index([schoolId, studentAId])
}

// ============================================================
// Wellness — counselor visits, mood check-ins, AI safeguarding
// ============================================================
model WellnessCheckIn {
  id         String   @id @default(cuid())
  schoolId   String
  studentId  String
  visitedAt  DateTime @default(now())
  counselorId String?
  symptoms   String?
  notes      String?
  followUpAt DateTime?
  createdAt  DateTime @default(now())

  @@index([schoolId, studentId])
  @@index([schoolId, visitedAt])
}

model MoodEntry {
  id         String   @id @default(cuid())
  schoolId   String
  studentId  String
  date       DateTime
  mood       String   // HAPPY | OK | SAD | ANGRY | ANXIOUS
  note       String?

  @@unique([studentId, date])
  @@index([schoolId, date])
}

model SafeguardingFlag {
  id         String   @id @default(cuid())
  schoolId   String
  studentId  String?
  source     String   // CONCERN | WALL | SUBMISSION | DIARY
  refId      String?
  category   String   // SELF_HARM | BULLYING | DISTRESS | SUBSTANCE | OTHER
  severity   String   @default("MEDIUM") // LOW | MEDIUM | HIGH
  excerpt    String
  reviewerId String?
  status     String   @default("OPEN")    // OPEN | REVIEWING | RESOLVED | FALSE_POSITIVE
  createdAt  DateTime @default(now())
  resolvedAt DateTime?

  @@index([schoolId, status])
  @@index([schoolId, severity])
}

// ============================================================
// Alumni — directory + mentorship
// ============================================================
model AlumniProfile {
  id          String   @id @default(cuid())
  schoolId    String
  userId      String?  // optional — alumni may sign up later
  fullName    String
  graduationYear Int
  email       String?
  phone       String?
  currentCompany String?
  currentRole    String?
  industry    String?
  city        String?
  linkedinUrl String?
  bio         String?
  willingToMentor Boolean @default(false)
  createdAt   DateTime @default(now())

  matches     MentorshipMatch[]

  @@index([schoolId, graduationYear])
}

model MentorshipMatch {
  id          String   @id @default(cuid())
  schoolId    String
  alumniId    String
  studentId   String
  topic       String   // CAREER | COLLEGE | INTERVIEW | OTHER
  status      String   @default("REQUESTED") // REQUESTED | ACCEPTED | DECLINED | COMPLETED
  notes       String?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  alumni      AlumniProfile @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
}

// ============================================================
// Reports — saved templates + custom report builder
// ============================================================
model ReportTemplate {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  category  String   // SIS | HR | FINANCE | TRANSPORT | LIBRARY | HOSTEL | LMS | CONNECT
  query     String   // JSON DSL describing entity, filters, columns, aggregations
  createdById String?
  createdAt DateTime @default(now())

  @@index([schoolId, category])
}

model SavedReport {
  id         String   @id @default(cuid())
  schoolId   String
  templateId String?
  name       String
  query      String   // JSON DSL snapshot
  result     String?  // JSON cached output
  generatedAt DateTime @default(now())
  generatedById String?

  @@index([schoolId, generatedAt])
}

// ============================================================
// Open API — keys + webhooks
// ============================================================
model ApiKey {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  prefix      String   // first 8 chars of the key for display
  hashedKey   String   // SHA-256 of the secret
  scopes      String   @default("read")  // comma-separated: read,write,admin
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  createdById String?

  @@unique([prefix])
  @@index([schoolId])
}

model WebhookSubscription {
  id         String   @id @default(cuid())
  schoolId   String
  url        String
  secret     String   // signing secret (HMAC)
  events     String   // comma-separated: invoice.paid,enquiry.created,...
  active     Boolean  @default(true)
  failures   Int      @default(0)
  lastDeliveredAt DateTime?
  lastError  String?
  createdAt  DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([schoolId, active])
}

model WebhookDelivery {
  id            String   @id @default(cuid())
  subscriptionId String
  event         String
  payload       String   // JSON
  status        String   // QUEUED | SENT | FAILED | RETRYING
  responseCode  Int?
  attempt       Int      @default(0)
  nextAttemptAt DateTime?
  createdAt     DateTime @default(now())
  deliveredAt   DateTime?

  subscription  WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status])
}

// ============================================================
