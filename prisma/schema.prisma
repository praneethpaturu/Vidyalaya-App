  studentId   String   @unique
  attendanceDays  Int  @default(0)
  homeworkDays    Int  @default(0)
  longestStreak   Int  @default(0)
  badges      String   @default("[]") // JSON list of badge codes
  updatedAt   DateTime @updatedAt

