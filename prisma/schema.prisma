  schoolId    String
  observerId  String   // staffId
  teacherId   String   // staffId
  classId     String
  observedAt  DateTime
  rubric      String   // JSON: per-parameter score
  feedback    String?
  actionPlan  String?
  followUpAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([schoolId, observedAt])
}

// ============================================================
// Connect — SMS / WhatsApp / Email / Voice
// ============================================================
// channel: SMS | WHATSAPP | EMAIL | VOICE
// status: DRAFT | SCHEDULED | SENDING | SENT | FAILED
model ConnectCampaign {
  id         String   @id @default(cuid())
  schoolId   String
  channel    String
  name       String
  templateId String?
  body       String
  audienceFilter String  // JSON: { role, classId, audience, etc. }
  scheduledAt DateTime?
  sentAt     DateTime?
  status     String   @default("DRAFT")
  recipients Int      @default(0)
  delivered  Int      @default(0)
  failed     Int      @default(0)
  createdById String?
  createdAt  DateTime @default(now())

  @@index([schoolId, status])
}

// channel: SMS | WHATSAPP | EMAIL
model ConnectTemplate {
  id        String   @id @default(cuid())
  schoolId  String
  channel   String
  name      String
  body      String
  approved  Boolean  @default(false)   // DLT-approved (SMS) or Meta-approved (WA)
  category  String?  // TRANSACTIONAL | PROMOTIONAL | OTP
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([schoolId, channel, name])
}

// SMS provider sender ID + DLT entity
model ConnectProvider {
  id        String   @id @default(cuid())
  schoolId  String
  channel   String   // SMS | WHATSAPP | EMAIL | VOICE
  name      String   // "MSG91" | "Twilio" | "Gupshup" | "SES"
  senderId  String?  // SMS header / WA business name
  dltEntityId String?
  apiKey    String?  // for demo only
  active    Boolean  @default(true)
  credits   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([schoolId, channel])
}

// ============================================================
// Library extensions — categories, fines, lexile
// ============================================================
model LibraryCategory {
  id        String  @id @default(cuid())
  schoolId  String
  name      String  // Reference | Textbook | Fiction | Periodical | Magazine
  active    Boolean @default(true)

  @@unique([schoolId, name])
}

model LibraryPublisher {
  id        String  @id @default(cuid())
  schoolId  String
  name      String
  contact   String?
  email     String?
  active    Boolean @default(true)

  @@unique([schoolId, name])
}

// Member type x Category -> days
model LibraryReturnDays {
  id          String  @id @default(cuid())
  schoolId    String
  memberType  String  // STUDENT | STAFF
  category    String
  days        Int
  graceDays   Int     @default(0)
  excludeWeekends Boolean @default(false)

  @@unique([schoolId, memberType, category])
}

model LibraryMaximumBooks {
  id          String  @id @default(cuid())
  schoolId    String
  memberType  String
  category    String
  maxBooks    Int
  classId     String?

  @@unique([schoolId, memberType, category, classId])
}

model LibraryFineRule {
  id          String  @id @default(cuid())
  schoolId    String
  category    String
  daysFrom    Int     // bucket lower bound (overdue days)
  daysTo      Int     // bucket upper bound; -1 = ∞
  amountPerDay Int    @default(0)   // paise
  flatAmount  Int     @default(0)   // paise (overrides per-day if > 0)
  capAmount   Int     @default(0)   // paise; 0 = no cap
  waiverAllowed Boolean @default(true)

  @@index([schoolId, category])
}

// Lexile / reading level assessment
model LexileGradeRange {
  id        String  @id @default(cuid())
  schoolId  String
  classId   String
  minLexile Int
  maxLexile Int

  @@unique([schoolId, classId])
}

model LexileBand {
  id        String  @id @default(cuid())
  schoolId  String
  label     String  // "Below Grade", "On Grade", "Above Grade"
  minLexile Int
  maxLexile Int

  @@unique([schoolId, label])
}

model LibraryAssessment {
  id        String  @id @default(cuid())
  schoolId  String
  studentId String
  conductedAt DateTime @default(now())
  scores    String   // JSON: { paramName: score }
  computedLexile Int  @default(0)
  band      String?
  recommendation String?
  conductedBy String?

  @@index([schoolId, studentId])
}

// ============================================================
// Transport additions — vehicle docs
// ============================================================
model VehicleDoc {
  id        String   @id @default(cuid())
  schoolId  String
  busId     String
  type      String   // FITNESS | PUC | INSURANCE | PERMIT
  number    String?
  validFrom DateTime?
  validTo   DateTime
  fileUrl   String?
  notes     String?

  @@index([schoolId, busId, validTo])
}

// Driver license / medical docs
model StaffDoc {
  id        String   @id @default(cuid())
  schoolId  String
  staffId   String
  type      String   // LICENSE | AADHAAR | PAN | MEDICAL | TRAINING
  number    String?
  validFrom DateTime?
  validTo   DateTime?
  fileUrl   String?
  notes     String?

  @@index([schoolId, staffId])
}

// ============================================================
// Concerns / Wall (school social feed)
// ============================================================
model WallPost {
  id         String   @id @default(cuid())
  schoolId   String
  authorId   String
  authorName String
  audience   String   @default("STAFF") // STAFF | STUDENTS | ALL
  body       String
  attachments String  @default("[]")
  pinned     Boolean  @default(false)
  flagged    Boolean  @default(false)
  createdAt  DateTime @default(now())

  comments   WallComment[]

  @@index([schoolId, createdAt])
}

model WallComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  authorName String
  body      String
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())

  post      WallPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ============================================================
// Subjects master + Learning taxonomy
// ============================================================
model SubjectMaster {
  id        String  @id @default(cuid())
  schoolId  String
  name      String
  code      String
  hasTheory Boolean @default(true)
  hasPractical Boolean @default(false)
  creditHours Int   @default(4)
  boardCsv  String  @default("CBSE")

  @@unique([schoolId, code])
}

model LearningTaxonomy {
  id        String  @id @default(cuid())
  schoolId  String
  name      String  // "Bloom", "SOLO"
  levelsCsv String  // "Remember,Understand,Apply,Analyse,Evaluate,Create"
  active    Boolean @default(true)

  @@unique([schoolId, name])
}

// ============================================================
// Reflections (student/teacher journal)
// ============================================================
model Reflection {
  id        String   @id @default(cuid())
  schoolId  String
  authorId  String
  authorRole String  // STUDENT | TEACHER
  mood      String?  // HAPPY | OK | TIRED | ANXIOUS | EXCITED
  title     String?
  body      String
  createdAt DateTime @default(now())

  @@index([schoolId, authorId])
}

// ============================================================
// Baseline analysis (LMS)
// ============================================================
model BaselineAssessment {
  id           String   @id @default(cuid())
  schoolId     String
  classId      String
  subjectId    String?
  type         String   @default("PRE")  // PRE | POST
  conductedAt  DateTime
  scores       String   // JSON: { studentId: score }
  totalMarks   Int
  notes        String?

  @@index([schoolId, classId])
}

// ============================================================
// Approvals (cross-module workflow queue)
// kind: ADMISSION | FEE_WAIVER | TC | DOC_EDIT | LEAVE | EXPENSE | REFUND | CONCESSION
// status: PENDING | APPROVED | REJECTED
// ============================================================
model ApprovalRequest {
  id           String   @id @default(cuid())
  schoolId     String
  kind         String
  refEntity    String?
  refId        String?
  summary      String
  payload      String   @default("{}")  // JSON
  requestedById String?
  approverId   String?
  status       String   @default("PENDING")
  decidedAt    DateTime?
  comment      String?
  createdAt    DateTime @default(now())

  @@index([schoolId, status])
  @@index([schoolId, kind])
}

// ============================================================
// Student favourite menus / saved pages
// ============================================================
model FavouriteMenu {
  id        String   @id @default(cuid())
  userId    String
  href      String
  label     String
  createdAt DateTime @default(now())

  @@unique([userId, href])
}

// ============================================================
// Visitor / Mentor / Hostel etc - more relations done.
// ============================================================

// ============================================================
// AI Insights (additive — new module sitting alongside existing data)
// ============================================================

// Generic insight produced by an AI feature; consumed by listing pages.
// kind examples: LEAD_SCORE | AT_RISK | DELINQUENCY | DRIVER_SCORE | ANOMALY |
//                COMPATIBILITY | MAINTENANCE | LEAVE_FORECAST | LEARNING_GAP
model AiInsight {
  id         String   @id @default(cuid())
  schoolId   String
  kind       String
  refEntity  String?  // "AdmissionEnquiry" | "Student" | "Bus" | "Staff" | ...
  refId      String?
  score      Float?   // 0..1
  band       String?  // "HIGH" | "MEDIUM" | "LOW" | model-specific
  reason     String?  // short human-readable rationale
  payload    String   @default("{}") // JSON for extra fields
  computedAt DateTime @default(now())

  @@index([schoolId, kind])
  @@index([refEntity, refId])
}

// AI-generated suggestions awaiting human review (essay grades, narrative drafts,
// translations, draft replies, etc.). status = PENDING | ACCEPTED | REJECTED.
model AiSuggestion {
  id         String   @id @default(cuid())
  schoolId   String
  kind       String   // ESSAY_GRADE | HPC_NARRATIVE | TRANSLATION | DRAFT_REPLY | QUIZ_GEN | ...
  refEntity  String?
  refId      String?
  prompt     String
  output     String
  meta       String   @default("{}")
  status     String   @default("PENDING")
  authorId   String?  // user who triggered
  reviewerId String?
  decidedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([schoolId, kind, status])
}

// Audit trail for every AI call (privacy / cost / debugging).
model AiAuditLog {
  id         String   @id @default(cuid())
  schoolId   String
  userId     String?
  feature    String
  provider   String   // "anthropic" | "stub"
  model      String?
  tokensIn   Int      @default(0)
  tokensOut  Int      @default(0)
  latencyMs  Int      @default(0)
  ok         Boolean  @default(true)
  errorMsg   String?
  createdAt  DateTime @default(now())

  @@index([schoolId, feature])
  @@index([schoolId, createdAt])
}

// Cached embeddings for semantic search / RAG.
// vector is a JSON array of floats; SQLite has no native vector type so we
// keep it portable. Cosine similarity computed in-memory.
model AiEmbedding {
  id         String   @id @default(cuid())
  schoolId   String
  refEntity  String   // "Student" | "Circular" | "Book" | "Concern" | ...
  refId      String
  text       String
  vector     String   // JSON float[]
  dim        Int
  createdAt  DateTime @default(now())

  @@unique([schoolId, refEntity, refId])
  @@index([schoolId, refEntity])
}

// Roommate compatibility scores (cached pairwise).
model AiCompatibility {
  id         String  @id @default(cuid())
  schoolId   String
  studentAId String
  studentBId String
  score      Float
  reasons    String  @default("[]") // JSON array
  computedAt DateTime @default(now())

  @@unique([schoolId, studentAId, studentBId])
  @@index([schoolId, studentAId])
}

// ============================================================
// Wellness — counselor visits, mood check-ins, AI safeguarding
// ============================================================
model WellnessCheckIn {
  id         String   @id @default(cuid())
  schoolId   String
  studentId  String
  visitedAt  DateTime @default(now())
  counselorId String?
  symptoms   String?
  notes      String?
  followUpAt DateTime?
  createdAt  DateTime @default(now())

  @@index([schoolId, studentId])
  @@index([schoolId, visitedAt])
}

model MoodEntry {
  id         String   @id @default(cuid())
  schoolId   String
  studentId  String
  date       DateTime
  mood       String   // HAPPY | OK | SAD | ANGRY | ANXIOUS
  note       String?

  @@unique([studentId, date])
  @@index([schoolId, date])
}

model SafeguardingFlag {
  id         String   @id @default(cuid())
  schoolId   String
  studentId  String?
  source     String   // CONCERN | WALL | SUBMISSION | DIARY
  refId      String?
  category   String   // SELF_HARM | BULLYING | DISTRESS | SUBSTANCE | OTHER
  severity   String   @default("MEDIUM") // LOW | MEDIUM | HIGH
  excerpt    String
  reviewerId String?
  status     String   @default("OPEN")    // OPEN | REVIEWING | RESOLVED | FALSE_POSITIVE
  createdAt  DateTime @default(now())
  resolvedAt DateTime?

  @@index([schoolId, status])
  @@index([schoolId, severity])
}

// ============================================================
// Alumni — directory + mentorship
// ============================================================
model AlumniProfile {
  id          String   @id @default(cuid())
  schoolId    String
  userId      String?  // optional — alumni may sign up later
  fullName    String
  graduationYear Int
  email       String?
  phone       String?
  currentCompany String?
  currentRole    String?
  industry    String?
  city        String?
  linkedinUrl String?
  bio         String?
  willingToMentor Boolean @default(false)
  createdAt   DateTime @default(now())

  matches     MentorshipMatch[]

  @@index([schoolId, graduationYear])
}

model MentorshipMatch {
  id          String   @id @default(cuid())
  schoolId    String
  alumniId    String
  studentId   String
  topic       String   // CAREER | COLLEGE | INTERVIEW | OTHER
  status      String   @default("REQUESTED") // REQUESTED | ACCEPTED | DECLINED | COMPLETED
  notes       String?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  alumni      AlumniProfile @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
}

// ============================================================
// Reports — saved templates + custom report builder
// ============================================================
model ReportTemplate {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  category  String   // SIS | HR | FINANCE | TRANSPORT | LIBRARY | HOSTEL | LMS | CONNECT
  query     String   // JSON DSL describing entity, filters, columns, aggregations
  createdById String?
  createdAt DateTime @default(now())

  @@index([schoolId, category])
}

model SavedReport {
  id         String   @id @default(cuid())
  schoolId   String
  templateId String?
  name       String
  query      String   // JSON DSL snapshot
  result     String?  // JSON cached output
  generatedAt DateTime @default(now())
  generatedById String?

  @@index([schoolId, generatedAt])
}

// ============================================================
// Open API — keys + webhooks
// ============================================================
model ApiKey {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  prefix      String   // first 8 chars of the key for display
  hashedKey   String   // SHA-256 of the secret
  scopes      String   @default("read")  // comma-separated: read,write,admin
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  createdById String?

  @@unique([prefix])
  @@index([schoolId])
}

model WebhookSubscription {
  id         String   @id @default(cuid())
  schoolId   String
  url        String
  secret     String   // signing secret (HMAC)
  events     String   // comma-separated: invoice.paid,enquiry.created,...
  active     Boolean  @default(true)
  failures   Int      @default(0)
  lastDeliveredAt DateTime?
  lastError  String?
  createdAt  DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([schoolId, active])
}

model WebhookDelivery {
  id            String   @id @default(cuid())
  subscriptionId String
  event         String
  payload       String   // JSON
  status        String   // QUEUED | SENT | FAILED | RETRYING
  responseCode  Int?
  attempt       Int      @default(0)
  nextAttemptAt DateTime?
  createdAt     DateTime @default(now())
  deliveredAt   DateTime?

  subscription  WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status])
}

// ============================================================
// Notification preferences (per-user channel toggles)
// ============================================================
model NotificationPreference {
  id        String  @id @default(cuid())
  userId    String  @unique
  email     Boolean @default(true)
  sms       Boolean @default(true)
  push      Boolean @default(true)
  whatsapp  Boolean @default(true)
  digestWeekly Boolean @default(true)
  language  String  @default("en") // en | hi | te | ta | kn | mr | ml
  updatedAt DateTime @updatedAt
}

// ============================================================
// Engagement — streaks, badges
// ============================================================
model StudentStreak {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String   @unique
  attendanceDays  Int  @default(0)
  homeworkDays    Int  @default(0)
  longestStreak   Int  @default(0)
  badges      String   @default("[]") // JSON list of badge codes
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
}

// ============================================================
// Compliance — DPDP Act, consent, data export requests
// ============================================================
model ConsentLog {
  id         String   @id @default(cuid())
  schoolId   String
  userId     String?
  subjectId  String?  // who the data is about (student id usually)
  purpose    String   // ENROLLMENT | COMMUNICATION | ANALYTICS | THIRD_PARTY
  granted    Boolean
  source     String   // FORM | EMAIL | CALL | UI
  recordedAt DateTime @default(now())
  expiresAt  DateTime?

  @@index([schoolId, subjectId])
}

model DataExportRequest {
  id          String   @id @default(cuid())
  schoolId    String
  requestedBy String   // user id
  subjectId   String   // student or staff id
  status      String   @default("PENDING")  // PENDING | READY | DELIVERED | DENIED
  reason      String?  // for denial
  fulfilledAt DateTime?
  exportUrl   String?  // Supabase Storage signed URL
  createdAt   DateTime @default(now())

  @@index([schoolId, status])
}

// ============================================================
// Government integrations — DigiLocker / UDISE+
// ============================================================
model DigiLockerIssuance {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String
  docType     String   // TC | TRANSCRIPT | BONAFIDE | ID_CARD
  uri         String?  // DigiLocker URI once pushed
  issuedAt    DateTime?
  status      String   @default("PENDING") // PENDING | ISSUED | FAILED
  errorMsg    String?
  createdAt   DateTime @default(now())

  @@index([schoolId, status])
}

model UDISEReport {
  id          String   @id @default(cuid())
  schoolId    String
  academicYear String
  status      String   @default("DRAFT") // DRAFT | SUBMITTED | ACCEPTED | REJECTED
  payload     String   // JSON of the full report
  fileUrl     String?  // generated XLS/JSON for upload
  submittedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([schoolId, academicYear])
}

// ============================================================
// Observability — error log captured server-side
// ============================================================
model ErrorLog {
  id         String   @id @default(cuid())
  schoolId   String?
  userId     String?
  level      String   @default("ERROR") // INFO | WARN | ERROR | FATAL
  message    String
  stack      String?
  route      String?
  request    String?  // JSON: method/url/ua
  createdAt  DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([level, createdAt])
}

// ============================================================
// Rate limit buckets (when not using Vercel KV / Redis)
// ============================================================
model RateLimitBucket {
  id        String  @id  // e.g. "ip:1.2.3.4:/api/ai/translate"
  count     Int     @default(0)
  resetAt   DateTime

  @@index([resetAt])
}

// ============================================================
// Admissions — Source + Stage masters (admin-defined, per school)
// ============================================================
model EnquirySource {
  id                String   @id @default(cuid())
  schoolId          String
  name              String
  isDigitalCampaign Boolean  @default(false)
  showAtBranchForm  Boolean  @default(true)
  showAtOnlineForm  Boolean  @default(true)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  @@unique([schoolId, name])
  @@index([schoolId, active])
}

model EnquiryStage {
  id                       String   @id @default(cuid())
  schoolId                 String
  name                     String
  level                    Int      @default(1)
  sequence                 Int      @default(0)
  isLeadCancel             Boolean  @default(false)
  dateCaptureEnabled       Boolean  @default(false)
  parentVisitOrSchoolTour  Boolean  @default(false)
  parentStageId            String?  // for substage hierarchy
  active                   Boolean  @default(true)
  createdAt                DateTime @default(now())

  @@unique([schoolId, name])
  @@index([schoolId, active])
  @@index([parentStageId])
}

// ============================================================
// Student promotion log — captures the AY transition
// ============================================================
model StudentPromotion {
  id               String   @id @default(cuid())
  schoolId         String
  studentId        String
  fromAcademicYear String
  toAcademicYear   String
  fromClassId      String?
  toClassId        String?
  type             String   // PASS_AND_PROMOTION | FINANCIAL_PROMOTION | DETAIN | ALUMNI | DROPOUT
  effectiveAt      DateTime @default(now())
  promotedById     String?
  reverted         Boolean  @default(false)
  revertedAt       DateTime?
  revertedById     String?
  notes            String?

  @@index([schoolId, toAcademicYear])
  @@index([studentId])
}

// ============================================================
// Monthly attendance — class+student aggregated per academic month
// ============================================================
model MonthlyAttendance {
  id              String   @id @default(cuid())
  schoolId        String
  studentId       String
  classId         String
  year            Int
  month           Int      // 1-12
  workingDays     Int      @default(0)
  presentDays     Int      @default(0)
  lateDays        Int      @default(0)
  earlyLeaveDays  Int      @default(0)
  remarks         String?
  enteredById     String?
  enteredAt       DateTime @default(now())

  @@unique([studentId, year, month])
  @@index([schoolId, year, month])
  @@index([classId, year, month])
}

// ============================================================
// Application form — concrete admission application (post-enquiry
// or direct). Promotes to a Student row once admitted.
// ============================================================
model ApplicationForm {
  id                String   @id @default(cuid())
  schoolId          String
  enquiryId         String?  // null = direct application
  applicationNo     String
  studentFirstName  String
  studentLastName   String?
  studentDob        DateTime?
  studentGender     String?
  optingClassId     String?
  optingClassName   String?
  admissionType     String?  // DAY_SCHOLAR | RESIDENTIAL | SEMI_RESIDENTIAL
  fatherName        String?
  fatherEmail       String?
  fatherPhone       String?
  motherName        String?
  motherEmail       String?
  motherPhone       String?
  address           String?
  previousSchool    String?
  vaccineStatus     String?
  needsTransport    Boolean  @default(false)
  documents         String   @default("[]") // JSON array of {name, url, uploadedAt}
  applicationFee    Int      @default(0)
  feePaid           Boolean  @default(false)
  feeReceiptNo      String?
  status            String   @default("OPEN") // OPEN | ACCEPTED | REJECTED | ADMITTED | CANCELLED
  expectedReportingDate DateTime?
  admittedStudentId String?  // FK to Student once admission happens
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([schoolId, applicationNo])
  @@index([schoolId, status])
  @@index([enquiryId])
}

// ============================================================
// Academic year master — multi-AY model
//
// Until now, School.academicYear held a single string. We keep that field
// (as the "current AY shortcut") but introduce AcademicYear so schools can
// see and switch between historical and future years without losing data.
// Marking a row isCurrent=true will sync School.academicYear in app code.
// ============================================================
model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  name      String   // "2026-2027"
  startsOn  DateTime
  endsOn    DateTime
  isCurrent Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([schoolId, name])
  @@index([schoolId, isCurrent])
}

// ============================================================
// Zonal layer — Group → Zone → Branch (School)
//
// A multi-school operator (chain) groups branches into zones for reporting.
// School.zoneId is a soft FK; null = unzoned. Zones don't enforce row-level
// visibility on their own — RBAC at the school level still gates data.
// ============================================================
model Zone {
  id        String   @id @default(cuid())
  groupId   String?
  name      String
  region    String?
  createdAt DateTime @default(now())

  @@index([groupId])
}

model OrgGroup {
  id        String   @id @default(cuid())
  name      String
  hqCity    String?
  createdAt DateTime @default(now())
}

// ============================================================
// Master subject taxonomy — cross-school subject catalogue.
// School-level Subject rows can reference a MasterSubject for reporting
// roll-up across branches and to enforce a consistent CBSE/IB code list.
// ============================================================
model MasterSubject {
  id          String   @id @default(cuid())
  code        String   @unique     // "MATH", "ENG-LIT", "PHY"
  name        String
  scope       String   @default("CORE")  // CORE | ELECTIVE | SKILL | LANGUAGE
  curriculum  String?  // CBSE | ICSE | IB | STATE
  createdAt   DateTime @default(now())
}

// ============================================================
// Store hierarchy — Inventory Category → Subcategory.
// Inventory items today carry a String category — this provides a typed
// taxonomy that the Store + Inventory pages can lean on.
// ============================================================
model StoreCategory {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  parentId  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([schoolId, name, parentId])
  @@index([schoolId, parentId])
}

// ============================================================
// Manage menus — per-role visibility overrides for nav modules.
// One row per (schoolId, role, moduleKey). visible=false hides the module
// from that role even if the default policy would allow it. Inserted lazily
// from the admin UI; absent rows fall back to defaults.
// ============================================================
model MenuVisibility {
  id        String   @id @default(cuid())
  schoolId  String
  role      String
  moduleKey String
  visible   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([schoolId, role, moduleKey])
  @@index([schoolId, role])
}

// ============================================================
// Student groups — Houses / Clubs / Sports / Activities.
// Multi-membership; one student can be in many groups.
// ============================================================
model StudentGroup {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  type      String   @default("CLUB")    // HOUSE | CLUB | SPORT | ACTIVITY
  color     String   @default("blue")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  members   StudentGroupMember[]

  @@unique([schoolId, name])
  @@index([schoolId, active])
}

// ============================================================
// Generic key/value setting bag — used by visitor / email / per-module
// preferences pages where defining a typed table per module is overkill.
// Values are JSON strings. Look up by (schoolId, key).
// ============================================================
model SchoolSetting {
  id        String   @id @default(cuid())
  schoolId  String
  key       String
  value     String   @default("{}")
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@unique([schoolId, key])
  @@index([schoolId])
}

// ============================================================
// Question Bank — school-scoped pool of reusable questions independent
// of any single OnlineExam. Authors can pull from the bank when creating
// an exam (server action copies into OnlineQuestion).
// ============================================================
model QuestionBankItem {
  id          String   @id @default(cuid())
  schoolId    String
  classId     String?
  subjectId   String?
  chapter     String?
  topic       String?
  text        String
  type        String   @default("MCQ")        // MCQ | MULTI | TRUE_FALSE | FILL | DESCRIPTIVE
  options     String   @default("[]")         // JSON array
  correct     String   @default("[]")         // JSON: indexes / "true"-"false" / text
  marks       Int      @default(1)
  difficulty  String   @default("MEDIUM")     // EASY | MEDIUM | HARD
  tags        String   @default("[]")
  active      Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())

  @@index([schoolId, classId, subjectId])
  @@index([schoolId, active])
}

// ============================================================
// PTM (Parent-Teacher Meeting) — schedule and feedback log.
// ============================================================
model PTM {
  id          String   @id @default(cuid())
  schoolId    String
  classId     String?     // null = school-wide
  title       String
  scheduledAt DateTime
  durationMin Int      @default(60)
  venue       String?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  feedback    PTMFeedback[]

  @@index([schoolId, scheduledAt])
}

model PTMFeedback {
  id         String   @id @default(cuid())
  ptmId      String
  studentId  String
  attended   Boolean  @default(false)
  parentName String?
  feedback   String?
  followUp   String?
  rating     Int?     // 1-5
  recordedById String?
  recordedAt DateTime @default(now())

  ptm        PTM      @relation(fields: [ptmId], references: [id], onDelete: Cascade)

  @@unique([ptmId, studentId])
}

// ============================================================
// Pre-Admission Exams — separate from OnlineExam; tied to applications.
// ============================================================
model PreAdmissionExam {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  optingClass String?     // free-text — application's optingClassName
  scheduledAt DateTime
  durationMin Int      @default(60)
  venue       String?
  totalMarks  Int      @default(100)
  passMarks   Int      @default(35)
  status      String   @default("SCHEDULED") // SCHEDULED | COMPLETED | CANCELLED
  createdById String?
  createdAt   DateTime @default(now())

  candidates  PreAdmissionCandidate[]
  subjects    PreAdmissionExamSubject[]

  @@index([schoolId, scheduledAt])
}

model PreAdmissionExamSubject {
  id        String  @id @default(cuid())
  examId    String
  name      String
  maxMarks  Int     @default(20)
  sequence  Int     @default(0)

  exam      PreAdmissionExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  scores    PreAdmissionScore[]

  @@unique([examId, name])
}

model PreAdmissionCandidate {
  id            String   @id @default(cuid())
  examId        String
  applicationId String?     // FK soft to ApplicationForm
  candidateName String
  parentPhone   String?
  hallTicketNo  String
  attendance    String   @default("PENDING")  // PENDING | PRESENT | ABSENT
  totalScore    Int      @default(0)
  result        String   @default("PENDING")  // PENDING | PASS | FAIL
  remarks       String?
  recordedAt    DateTime @default(now())

  exam          PreAdmissionExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  scores        PreAdmissionScore[]

  @@unique([examId, hallTicketNo])
}

model PreAdmissionScore {
  id             String   @id @default(cuid())
  candidateId    String
  examSubjectId  String
  marks          Int      @default(0)

  candidate      PreAdmissionCandidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  examSubject    PreAdmissionExamSubject  @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)

  @@unique([candidateId, examSubjectId])
}

// ============================================================
// Bank Reconciliation — operator uploads a bank statement; we match
// rows against existing Payment records by amount + reference and
// flag mismatches for review.
// ============================================================
model BankStatementImport {
  id           String   @id @default(cuid())
  schoolId     String
  fileName     String?
  uploadedAt   DateTime @default(now())
  uploadedById String?
  rowCount     Int      @default(0)
  matchedCount Int      @default(0)
  unmatchedCount Int    @default(0)

  rows         BankStatementRow[]

  @@index([schoolId, uploadedAt])
}

model BankStatementRow {
  id            String   @id @default(cuid())
  importId      String
  txnDate       DateTime
  description   String
  reference     String?
  debit         Int      @default(0)   // paise
  credit        Int      @default(0)
  balance       Int      @default(0)
  matchedPaymentId String?
  status        String   @default("UNMATCHED") // UNMATCHED | MATCHED | IGNORED

  import        BankStatementImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId, status])
}

// ============================================================
// Holiday master — per-school list of dated holidays. Combined with the
// SchoolSetting "workingDays" array (e.g. [1,2,3,4,5,6] = Mon-Sat) to drive
// attendance calculations and the monthly working-day count.
// ============================================================
model Holiday {
  id          String   @id @default(cuid())
  schoolId    String
  date        DateTime
  name        String
  category    String   @default("PUBLIC")  // PUBLIC | LOCAL | RELIGIOUS | OBSERVANCE | EXAM_BREAK | VACATION
  fullDay     Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())

  @@unique([schoolId, date])
  @@index([schoolId, date])
}

// ============================================================
// Inter-branch student transfer — used when a chain has multiple schools and
// a student moves from one branch to another. The Student row stays in the
// source branch as a historical record; a new Student is created in the
// destination branch. We log the transfer for auditing.
// ============================================================
model StudentTransfer {
  id              String   @id @default(cuid())
  fromSchoolId    String
  toSchoolId      String
  studentId       String   // source-side student id (will be soft-deleted there)
  newStudentId    String?  // destination-side student id (created post-transfer)
  effectiveAt     DateTime @default(now())
  reason          String?
  initiatedById   String?
  status          String   @default("INITIATED")  // INITIATED | COMPLETED | CANCELLED
  createdAt       DateTime @default(now())

  @@index([fromSchoolId, status])
  @@index([toSchoolId, status])
}

// ============================================================
// Exam invigilator allocation + seating plan.
// ============================================================
model ExamInvigilator {
  id            String   @id @default(cuid())
  examSubjectId String
  staffId       String
  room          String?
  notes         String?

  @@unique([examSubjectId, staffId])
  @@index([examSubjectId])
}

model ExamSeating {
  id            String   @id @default(cuid())
  examSubjectId String
  studentId     String
  room          String
  rowNo         Int
  seatNo        Int

  @@unique([examSubjectId, studentId])
  @@index([examSubjectId, room])
}

// ============================================================
// Tally ERP exports — audit trail of generated XMLs.
// ============================================================
model TallyExport {
  id            String   @id @default(cuid())
  schoolId      String
  type          String   // VOUCHERS | RECEIPTS | PAYMENTS | LEDGERS
  fromDate      DateTime
  toDate        DateTime
  rowCount      Int      @default(0)
  generatedById String?
  generatedAt   DateTime @default(now())

  @@index([schoolId, generatedAt])
}

// ============================================================
// OMR (Optical Mark Recognition) sheets — one per exam-subject.
// ============================================================
model OMRSheet {
  id              String   @id @default(cuid())
  schoolId        String
  examSubjectId   String   @unique
  title           String
  questionCount   Int      @default(0)
  optionCount     Int      @default(4)
  marksPerCorrect Float    @default(1)
  negativeMarks   Float    @default(0)
  answerKey       String   @default("[]")
  generatedAt     DateTime @default(now())

  responses       OMRResponse[]
}

model OMRResponse {
  id          String   @id @default(cuid())
  sheetId     String
  studentId   String
  responses   String   @default("[]")
  scoredMarks Float    @default(0)
  scannedAt   DateTime @default(now())
  scannedById String?

  sheet       OMRSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@unique([sheetId, studentId])
}

// ============================================================
// Fixed asset register + per-FY depreciation entries.
// ============================================================
model FixedAsset {
  id                 String   @id @default(cuid())
  schoolId           String
  assetCode          String
  name               String
  category           String   @default("OTHER")
  purchaseDate       DateTime
  purchaseCost       Int
  vendor             String?
  location           String?
  depreciationMethod String   @default("STRAIGHT_LINE")
  usefulLifeYears    Int      @default(5)
  wdvRatePct         Float    @default(15)
  salvageValue       Int      @default(0)
  status             String   @default("ACTIVE")
  disposedAt         DateTime?
  disposalNotes      String?
  createdAt          DateTime @default(now())

  entries            AssetDepreciationEntry[]

  @@unique([schoolId, assetCode])
  @@index([schoolId, status])
}

model AssetDepreciationEntry {
  id             String   @id @default(cuid())
  assetId        String
  fy             String
  amount         Int
  method         String
  bookValueAfter Int
  recordedAt     DateTime @default(now())

  asset          FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, fy])
}

// ============================================================
// RTE 25% quota — flag a student admission as RTE-mandate intake.
// ============================================================
model RTEAdmission {
  id           String   @id @default(cuid())
  schoolId     String
  studentId    String   @unique
  fy           String
  district     String?
  category     String?
  documentUrl  String?
  approvedAt   DateTime?
  approvedById String?
  notes        String?
  createdAt    DateTime @default(now())

  @@index([schoolId, fy])
}

// ============================================================
// Alumni donations — pledge → received → 80G-style receipt.
// ============================================================
model AlumniDonation {
  id              String   @id @default(cuid())
  schoolId        String
  alumniProfileId String?
  donorName       String
  donorEmail      String?
  donorPhone      String?
  donorPan        String?
  amount          Int
  purpose         String?
  pledgedAt       DateTime?
  receivedAt      DateTime?
  receiptNo       String?
  status          String   @default("PLEDGED")
  notes           String?
  createdAt       DateTime @default(now())

  @@unique([schoolId, receiptNo])
  @@index([schoolId, status])
}

// ============================================================
// Drip campaigns — sequenced communications over time.
// ============================================================
model DripCampaign {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  audience    String   @default("ALL")
  classId     String?
  active      Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())

  steps       DripStep[]

  @@index([schoolId, active])
}

model DripStep {
  id         String   @id @default(cuid())
  campaignId String
  sequence   Int
  delayDays  Int      @default(0)
  channel    String   @default("SMS")
  subject    String?
  body       String

  campaign    DripCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  enrollments DripEnrollment[]

  @@unique([campaignId, sequence])
}

model DripEnrollment {
  id          String   @id @default(cuid())
  stepId      String
  userId      String
  scheduledAt DateTime
  sentAt      DateTime?
  status      String   @default("SCHEDULED")

  step        DripStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([scheduledAt, status])
  @@index([stepId, userId])
}

// ============================================================
// CPD — staff training log.
// ============================================================
model CPDActivity {
  id             String   @id @default(cuid())
  schoolId       String
  staffId        String
  title          String
  type           String   @default("WORKSHOP")
  hours          Float    @default(0)
  completedAt    DateTime
  certificateUrl String?
  notes          String?
  recordedById   String?
  createdAt      DateTime @default(now())

  @@index([schoolId, staffId])
  @@index([schoolId, completedAt])
}

// ============================================================
// Infirmary — sick-bay visit log.
// ============================================================
model InfirmaryVisit {
  id             String   @id @default(cuid())
  schoolId       String
  studentId      String?
  staffId        String?
  visitedAt      DateTime @default(now())
  symptoms       String
  diagnosis      String?
  medication     String?
  vitals         String?
  outcome        String   @default("RETURNED_TO_CLASS")
  parentNotified Boolean  @default(false)
  recordedById   String?

  @@index([schoolId, visitedAt])
  @@index([studentId])
}

// ============================================================
// PDC — post-dated cheque register.
// ============================================================
model PDCCheque {
  id          String   @id @default(cuid())
  schoolId    String
  drawerName  String
  drawerPhone String?
  bankName    String?
  chequeNo    String
  amount      Int
  dueDate     DateTime
  status      String   @default("PENDING")
  depositedAt DateTime?
  invoiceId   String?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([schoolId, status, dueDate])
}

// ============================================================
// Recruitment — job openings + applicants.
// ============================================================
model JobOpening {
  id             String   @id @default(cuid())
  schoolId       String
  title          String
  department     String?
  employmentType String   @default("FULL_TIME")
  description    String
  requirements   String?
  closeAt        DateTime?
  status         String   @default("OPEN")
  createdById    String?
  createdAt      DateTime @default(now())

  applicants     JobApplicant[]

  @@index([schoolId, status])
}

model JobApplicant {
  id              String   @id @default(cuid())
  openingId       String
  name            String
  email           String?
  phone           String?
  resumeUrl       String?
  currentEmployer String?
  status          String   @default("NEW")
  notes           String?
  appliedAt       DateTime @default(now())

  opening         JobOpening @relation(fields: [openingId], references: [id], onDelete: Cascade)

  @@index([openingId, status])
}

// ============================================================
// PMS — staff goals + reviews.
// ============================================================
model StaffGoal {
  id          String   @id @default(cuid())
  schoolId    String
  staffId     String
  fy          String
  title       String
  description String?
  kpi         String?
  weight      Int      @default(20)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  reviews     StaffReview[]

  @@index([schoolId, fy, staffId])
}

model StaffReview {
  id           String   @id @default(cuid())
  goalId       String
  period       String   @default("MID")
  rating       Int?
  comments     String?
  reviewedById String?
  reviewedAt   DateTime @default(now())

  goal         StaffGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, period])
}

// ============================================================
// PoSH — Prevention of Sexual Harassment Act 2013 register.
// Per-school complaint tracker with Internal Committee (IC) members,
// hearings, and final resolution. Confidentiality: only ADMIN, PRINCIPAL,
// HR_MANAGER (and IC members) can read.
// ============================================================
model PoshComplaint {
  id              String   @id @default(cuid())
  schoolId        String
  caseNo          String
  filedAt         DateTime @default(now())
  filedById       String?
  complainantName String
  complainantRole String?              // STAFF | STUDENT | PARENT | OTHER
  respondentName  String
  respondentRole  String?
  incidentDate    DateTime?
  incidentLocation String?
  natureOfIncident String
  evidenceUrl     String?
  status          String   @default("FILED") // FILED | UNDER_INQUIRY | RESOLVED | DISMISSED | WITHDRAWN
  closedAt        DateTime?
  closingNote     String?
  recommendation  String?              // ICOC recommendation text
  actionTaken     String?              // school's final action

  hearings        PoshHearing[]

  @@unique([schoolId, caseNo])
  @@index([schoolId, status])
}

model PoshHearing {
  id          String   @id @default(cuid())
  complaintId String
  scheduledAt DateTime
  attendees   String?              // free text comma-list
  notes       String?
  outcome     String?
  recordedAt  DateTime @default(now())

  complaint   PoshComplaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId, scheduledAt])
}

// ============================================================
// Push notification token registry. The native shells (Capacitor / iOS /
// Android web push) call POST /api/push/register on login to deposit their
// device token. PUSH-channel outbox rows pick up active tokens via toUserId
// and dispatch through FCM/APNs (provider step is wired generically; until
// a real key is set, sends are logged as push-stub).
// ============================================================
model PushToken {
  id         String   @id @default(cuid())
  userId     String
  token      String
  platform   String   @default("WEB")
  deviceTag  String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@unique([userId, token])
  @@index([userId, active])
}

// ============================================================
// Scheduled report subscription — fires a preset / custom report on a
// cadence and emails the CSV to the configured recipients.
// ============================================================
model ReportSubscription {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  preset      String                                    // matches PRESETS.key in lib/reports/runner
  cadence     String   @default("WEEKLY")               // DAILY | WEEKLY | MONTHLY
  recipients  String   @default("[]")                    // JSON array of email strings
  active      Boolean  @default(true)
  nextRunAt   DateTime
  lastRunAt   DateTime?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([active, nextRunAt])
  @@index([schoolId])
}

// ============================================================
// Self-hosted help video library — seeded with our own tutorials.
// videoUrl can point at a static file in /public, an S3 / Supabase Storage
// signed URL, or any HTTPS endpoint that serves video/* mime-types.
// Global (no schoolId) — same library across every tenant.
// ============================================================
model HelpVideo {
  id           String   @id @default(cuid())
  module       String                              // SIS | HR | Finance | Library | Admissions | …
  title        String
  description  String?
  durationSec  Int      @default(0)
  videoUrl     String                              // mp4 / webm
  thumbnailUrl String?
  posterColor  String   @default("brand")          // for placeholder card backgrounds
  sequence     Int      @default(0)                // display order within module
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([module, sequence])
  @@index([active])
}

// ============================================================
// Support / training requests — covers Help-menu actions:
// "Raise a ticket" (TICKET), "Book training with Account Manager" (TRAINING_AM),
// "Book CSM meeting" (CSM_MEETING), "Give feedback" (FEEDBACK).
// ============================================================
model SupportRequest {
  id             String   @id @default(cuid())
  schoolId       String
  requestedById  String?
  requestedByName String
  type           String                          // TICKET | TRAINING_AM | CSM_MEETING | FEEDBACK
  subject        String
  body           String
  preferredAt    DateTime?
  rating         Int?                            // for feedback type
  contactPhone   String?
  contactEmail   String?
  status         String   @default("OPEN")       // OPEN | SCHEDULED | RESOLVED | CANCELLED
  scheduledAt    DateTime?
  resolutionNote String?
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())

  @@index([schoolId, type, status])
  @@index([schoolId, createdAt])
}

// ============================================================
// Pickup requests — parent self-serve early-pickup.
// ============================================================
model PickupRequest {
  id             String   @id @default(cuid())
  schoolId       String
  studentId      String
  requestedById  String
  pickupAt       DateTime
  reason         String
  pickerName     String?
  pickerPhone    String?
  pickerRelation String?
  status         String   @default("PENDING")
  decidedById    String?
  decidedAt      DateTime?
  decisionNote   String?
  createdAt      DateTime @default(now())

  @@index([schoolId, status, pickupAt])
  @@index([studentId])
}

model StudentGroupMember {
  id         String   @id @default(cuid())
  groupId    String
  studentId  String
  role       String?  // captain | vice-captain | member
  joinedAt   DateTime @default(now())

  group      StudentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
}
