// status: DRAFT | SUBMITTED | APPROVED | PUBLISHED
model ContentItem {
  id        String   @id @default(cuid())
  schoolId  String
  classId   String?
  subjectId String?
  chapter   String?
  topic     String?
  title     String
  type      String   // PDF | VIDEO | LINK | DOC | EBOOK
