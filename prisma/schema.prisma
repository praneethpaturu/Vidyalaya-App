  busId     String
  type      String   // FITNESS | PUC | INSURANCE | PERMIT
  number    String?
  validFrom DateTime?
  validTo   DateTime
  fileUrl   String?
  notes     String?

  @@index([schoolId, busId, validTo])
}

// Driver license / medical docs
model StaffDoc {
  id        String   @id @default(cuid())
  schoolId  String
  staffId   String
  type      String   // LICENSE | AADHAAR | PAN | MEDICAL | TRAINING
  number    String?
  validFrom DateTime?
  validTo   DateTime?
  fileUrl   String?
  notes     String?

  @@index([schoolId, staffId])
}

// ============================================================
// Concerns / Wall (school social feed)
// ============================================================
model WallPost {
