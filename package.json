{
  "name": "vidyalaya",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "vercel-build": "next build",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:mcb": "tsx prisma/seed-mcb.ts",
    "db:reset": "rm -f prisma/dev.db && prisma db push && tsx prisma/seed.ts && tsx prisma/seed-mcb.ts",
    "setup": "npm install && npm run db:reset"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
