# Local development env. Copy to .env (which is gitignored) and fill in.
# Production values live in Vercel project settings, not in this file.

# ─── Database (Supabase Postgres) ──────────────────────────────────────
# Pooled URL — used by the running app (Vercel functions, local Next.js).
# From Supabase → Project Settings → Database → Transaction pooler.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct URL — used only by `prisma migrate` and seed scripts.
# From Supabase → Project Settings → Database → Session pooler / Direct connection.
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# ─── NextAuth ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-locally-and-set-a-fresh-value-in-vercel"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# ─── Supabase Storage ──────────────────────────────────────────────────
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<anon-public-jwt>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-jwt-server-only>"
SUPABASE_BUCKET="uploads"

# ─── AI provider (optional) ────────────────────────────────────────────
# Set OPENAI_API_KEY (preferred) or ANTHROPIC_API_KEY. Both unset → stub mode.
OPENAI_API_KEY=""
AI_MODEL="gpt-4o-mini"

# ─── Email (transactional: invites, password resets) ──────────────────
# Any SMTP-compatible provider works (Resend, SES, Postmark, Mailgun, Gmail
# app password, Mailtrap for dev). Leave all four unset to log emails to
# stdout instead of sending — useful for local development.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Vidyalaya <no-reply@yourdomain.com>"

# Public base URL the app is served from. Used in email links.
APP_URL="http://localhost:3000"
